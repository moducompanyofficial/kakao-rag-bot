# ── 무료 티어 (기본): Google AI Studio 키 하나면 임베딩+생성 모두 동작 ──
# 발급: https://aistudio.google.com/apikey (구글 계정만 필요, 카드 등록 불필요)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ── 유료 업그레이드 (납품용, 선택): 키가 있으면 자동으로 이쪽 사용 ──
